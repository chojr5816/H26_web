<!DOCTYPE html>
<html>
<head>
    <title>뱀게임</title>
    <style>
        body { text-align: center; background: #1a1a1a; color: white; font-family: 'Malgun Gothic', sans-serif; }
        #scoreBoard { display: flex; justify-content: center; gap: 30px; font-size: 20px; margin-top: 10px; }
        canvas { background: #222; display: block; margin: 20px auto; border: 5px solid #444; border-radius: 8px; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
        .info { color: #aaa; font-size: 14px; }
    </style>
</head>
<body>
    <h1>🐍 SNAKE UPGRADE</h1>
    <div id="scoreBoard">
        <div>현재 점수: <span id="score" style="color: #4CAF50; font-weight: bold;">0</span></div>
        <div>레벨: <span id="level" style="color: #2196F3; font-weight: bold;">1</span></div>
        <div>최고 점수: <span id="highScore" style="color: #FFC107; font-weight: bold;">0</span></div>
    </div>
    <canvas id="gameCanvas" width="400" height="400"></canvas>
    
    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const gridSize = 20;
        const tileCount = 20;

        let snake = [{x: 10, y: 10}];
        let food = {x: 5, y: 5, isGold: false}; // 사과 종류 상태 추가
        let dx = 1; 
        let dy = 0; 
        let score = 0;
        let level = 1;
        let gameSpeed = 120; // 초기 속도 (밀리초)
        let gameLoopTimeout;

        // 로컬 스토리지에서 최고 점수 불러오기
        let highScore = localStorage.getItem("snakeHighScore") || 0;
        document.getElementById("highScore").innerText = highScore;

        function startGame() {
            // 게임 루프 실행 (setInterval 대신 setTimeout을 써야 동적으로 속도를 변경할 수 있습니다)
            gameLoopTimeout = setTimeout(drawGame, gameSpeed);
        }

        function createFood() {
            // 20% 확률로 황금 사과 등장
            const isGold = Math.random() < 0.2;
            food = {
                x: Math.floor(Math.random() * tileCount),
                y: Math.floor(Math.random() * tileCount),
                isGold: isGold
            };
            
            // 사과가 뱀 몸 위에 생기지 않도록 방지
            if (snake.some(segment => segment.x === food.x && segment.y === food.y)) {
                createFood();
            }
        }

        function drawGame() {
            const head = {x: snake[0].x + dx, y: snake[0].y + dy};
            
            // 벽 처리 및 충돌 검사
            if (head.x < 0 || head.x >= tileCount || head.y < 0 || head.y >= tileCount || 
                snake.some(segment => segment.x === head.x && segment.y === head.y)) {
                
                // 최고 점수 업데이트 검사
                if (score > highScore) {
                    highScore = score;
                    localStorage.setItem("snakeHighScore", highScore);
                    document.getElementById("highScore").innerText = highScore;
                    alert(`🎉 축하합니다! 최고 점수 달성: ${score}점`);
                } else {
                    alert(`게임 오버! 점수: ${score}점`);
                }

                // 게임 초기화
                snake = [{x: 10, y: 10}]; dx = 1; dy = 0; score = 0; level = 1; gameSpeed = 120;
                document.getElementById("score").innerText = score;
                document.getElementById("level").innerText = level;
                createFood();
                startGame();
                return;
            }

            snake.unshift(head);

            // 사과를 먹었을 때 로직
            if (head.x === food.x && head.y === food.y) {
                if (food.isGold) {
                    score += 30; // 황금 사과는 30점
                    snake.pop(); // 황금 사과는 몸이 늘어나지 않음! (치트키 역할)
                } else {
                    score += 10; // 일반 사과는 10점
                    // 일반 사과는 pop을 하지 않아 몸이 늘어남
                }
                
                // 50점 획득할 때마다 레벨업 및 속도 업!
                level = Math.floor(score / 50) + 1;
                gameSpeed = Math.max(50, 130 - (level * 10)); // 레벨이 오를수록 빨라짐 (최대 속도 제한)

                document.getElementById("score").innerText = score;
                document.getElementById("level").innerText = level;
                createFood();
            } else {
                snake.pop();
            }

            // 그리기 영역
            ctx.fillStyle = "#222";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 격자 무늬 배경 살짝 넣기 (시각적 효과)
            ctx.strokeStyle = "#2b2b2b";
            for(let i=0; i<tileCount; i++) {
                ctx.beginPath(); ctx.moveTo(i*gridSize, 0); ctx.lineTo(i*gridSize, canvas.height); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(0, i*gridSize); ctx.lineTo(canvas.width, i*gridSize); ctx.stroke();
            }

            // 사과 그리기
            if (food.isGold) {
                ctx.fillStyle = "#FFD700"; // 황금색
                ctx.shadowBlur = 10; ctx.shadowColor = "#FFD700"; // 반짝이는 효과
            } else {
                ctx.fillStyle = "#FF4136"; // 일반 빨간색
                ctx.shadowBlur = 0;
            }
            ctx.fillRect(food.x * gridSize + 1, food.y * gridSize + 1, gridSize - 2, gridSize - 2);
            ctx.shadowBlur = 0; // 그림자 초기화

            // 뱀 그리기
            snake.forEach((segment, index) => {
                // 머리는 진한 초록, 몸통은 연한 초록색으로 구분
                ctx.fillStyle = index === 0 ? "#2ECC40" : "#3D9970";
                ctx.fillRect(segment.x * gridSize + 1, segment.y * gridSize + 1, gridSize - 2, gridSize - 2);
            });

            // 다음 프레임 예약
            gameLoopTimeout = setTimeout(drawGame, gameSpeed);
        }

        // 키보드 조작
        window.addEventListener("keydown", e => {
            if (e.key === "ArrowUp" && dy !== 1) { dx = 0; dy = -1; }
            if (e.key === "ArrowDown" && dy !== -1) { dx = 0; dy = 1; }
            if (e.key === "ArrowLeft" && dx !== 1) { dx = -1; dy = 0; }
            if (e.key === "ArrowRight" && dx !== -1) { dx = 1; dy = 0; }
        });

        // 게임 시작
        createFood();
        startGame();
    </script>
</body>
</html>
